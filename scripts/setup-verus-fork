#!/bin/bash
#
# setup-verus-fork — Clone verus-lang/verus, create a branch, build it.
#
# Creates ~/projects/verus-patched/ with the patched verus build.
# The original ~/projects/verus/ is left untouched.
#
# Usage:
#   ./setup-verus-fork [--apply-patch]
#
# With --apply-patch, applies patches/drop-vir-krate-early.patch after cloning.
# Without it, just clones and builds (for baseline measurement).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
VERUS_UPSTREAM="https://github.com/verus-lang/verus.git"
VERUS_COMMIT="76e69b81"  # Pinned commit matching the analysis
VERUS_PATCHED="$HOME/projects/verus-patched"
APPLY_PATCH=false

for arg in "$@"; do
    case "$arg" in
        --apply-patch) APPLY_PATCH=true ;;
        *) echo "Unknown arg: $arg"; exit 1 ;;
    esac
done

echo "=== Setting up verus fork at $VERUS_PATCHED ==="

if [ -d "$VERUS_PATCHED" ]; then
    echo "Directory $VERUS_PATCHED already exists."
    echo "Remove it first if you want a fresh clone:"
    echo "  rm -rf $VERUS_PATCHED"
    exit 1
fi

# Clone.
echo "Cloning verus-lang/verus..."
git clone "$VERUS_UPSTREAM" "$VERUS_PATCHED"
cd "$VERUS_PATCHED"
git checkout "$VERUS_COMMIT"

# Create branch.
git checkout -b heaptrack-memory-fix

# Apply patch if requested.
if $APPLY_PATCH; then
    echo "Applying drop-vir-krate-early patch..."
    git apply "$SCRIPT_DIR/patches/drop-vir-krate-early.patch"
    git add -A
    git commit -m "Drop VIR Krate after SST conversion to reduce peak memory

Releases the VIR Krate (paths, expressions, types) as soon as SST conversion
completes, rather than holding it through the entire Z3 verification phase.

Estimated savings: ~300 MB on large crates (APAS-VERUS workload).

See: https://github.com/verus-lang/verus/issues/XXXX"
fi

# Build.
echo "Building verus (vargo build --release)..."
cd source
# vargo is the verus build tool; it sets up the correct env.
./tools/vargo/target/release/vargo build --release 2>&1 || {
    echo ""
    echo "If vargo is not built yet, build it first:"
    echo "  cd $VERUS_PATCHED/source/tools/vargo && cargo build --release"
    echo "Then re-run this script."
    exit 1
}

echo ""
echo "=== Build complete ==="
echo "Patched binaries at: $VERUS_PATCHED/source/target-verus/release/"
echo ""
echo "To profile:"
echo "  VERUS_ROOT=$VERUS_PATCHED/source/target-verus/release \\"
echo "    $SCRIPT_DIR/scripts/verus-heaptrack src/lib.rs --num-threads 8"
echo ""
echo "To benchmark:"
echo "  $SCRIPT_DIR/scripts/verus-benchmark src/lib.rs"
